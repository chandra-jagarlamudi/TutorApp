{
  "name": "TutorApp",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y python3 make g++ && npm install && npm rebuild better-sqlite3",
  "postStartCommand": "npm run dev",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Next.js",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "runArgs": ["--add-host=host.docker.internal:host-gateway"],
  "mounts": [
    "source=${localWorkspaceFolder}/.env.local,target=/workspaces/TutorApp/.env.local,type=bind,consistency=cached"
  ],
  "remoteEnv": {
    "NODE_ENV": "development",
    "OLLAMA_HOST": "http://host.docker.internal:11434"
  }
}
